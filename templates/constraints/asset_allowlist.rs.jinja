// --- asset_allowlist ---
// Restricts the invoked target contract (`contract` from the ContractContext)
// to the listed StrKey C-addresses. Default-reject via AssetNotAllowed.
{
    let mut matched = false;
{%- for asset in asset_allowlist %}
    {
        let allowed = Address::from_string(&String::from_str(e, "{{ asset }}"));
        if contract == &allowed {
            matched = true;
        }
    }
{%- endfor %}
    if !matched {
        panic_with_error!(e, PolicyError::AssetNotAllowed);
    }
}
