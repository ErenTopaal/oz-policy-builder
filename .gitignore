# rust
target/
**/*.rs.bk
*.swp

# node / pnpm
node_modules/
dist/
*.tsbuildinfo
.pnpm-store/

# os / editor
.DS_Store
.vscode/
.idea/
*.iml

# env / secrets
.env
.env.*
*.local
secrets/

# logs / tmp
*.log
tmp/
target-tmp/

# build caches / manifests not committed
reproducible-build-manifest-*.json
.docker-cargo-home/
.docker-target/

# fuzz scratch
crates/*/fuzz/corpus/
crates/*/fuzz/artifacts/

# worktrees
.worktrees/
.claude/worktrees/

# project-specific docs / reports we don't publish
*.md
!README.md
!LICENSE-APACHE
!skills/**/*.md
researches/
audits/
docs/
plan.md
STATUS.md
HANDOFF.md
CHANGELOG.md
NOTICE
completion.md

# allow everything under docs-site/ (Fumadocs source). overrides *.md, docs/,
# and *.mdx-as-md ignore rules above so the content directory is tracked.
!docs-site/**

# personal scratch / probes
_probe*.mjs
_probe*.ts
_probe*.py
scratch/
.superpowers/

# brainstorm / design canvas artifacts
*.dc.html
playground-design/
*Dev Tool Dashboard*

# playwright (also in frontend/.gitignore)
test-results/
playwright-report/
